# ─── FlipFlow Pro — Environment Variables ───

# ── Server ──
PORT=3001
NODE_ENV=development

# ── Authentication ──
# REQUIRED in production. Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ── CORS (production only) ──
# Set to your frontend URL to restrict cross-origin requests
# APP_URL=https://yourdomain.com

# ── eBay API ──
# Register at https://developer.ebay.com
EBAY_APP_ID=your_ebay_app_id
EBAY_CERT_ID=your_ebay_cert_id
EBAY_MARKETPLACE=EBAY_DE

# ── Etsy API ──
# Register at https://www.etsy.com/developers
ETSY_API_KEY=your_etsy_api_key
